@prefix : <https://www.w3id.org/MachPP/> .
@prefix cm: <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#> .
@prefix co: <https://w3id.org/pmd/co/> .
@prefix odp: <http://www.ontologydesignpatterns.org/cp/owl/partof.owl> .
@prefix org: <https://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix marco: <https://resourcedescription.rd.tuni.fi/ontology/resourceModel#> .
@prefix MachPP: <https://www.w3id.org/MachPP#> .
@prefix kg4cut: <https://w3id.org/kg4cut/> .
@base <https://www.w3id.org/MachPP/> .

<https://w3id.org/MachPP> rdf:type owl:Ontology ;
                           owl:versionIRI <MachPP:1.0.9> ;
                           owl:imports <http://www.ontologydesignpatterns.org/cp/owl/partof.owl> ,
                                       <https://resourcedescription.rd.tuni.fi/ontology/resourceModel> ,
                                       <https://w3id.org/kg4cut/1.3.0> ;
                           <http://creativecommons.org/ns#license> "https://creativecommons.org/licenses/by/4.0/" ;
                           <http://purl.org/dc/elements/1.1/creator> "Beatriz Olarte" ;
                           <http://purl.org/dc/elements/1.1/description> """This ontology contains information and knowledge required to produce machining tasks and processes. This information is normally contained in route cards, giving its fine granularity level, it is decomposed into machining tasks. MachPP allows mapping information from machining processes to route cards. Allowing the usage of manufacturing features as input and output to each machining task to link it to the machining specifications selected by experts. 
The ontology is linked to MarCo ontology and kg4cut, enabling to map the assets requested by a full machine tending quote or even a final project."""@en ;
                           <http://purl.org/dc/elements/1.1/title> "Machining Process Planning Ontology (MachPP)"@en ;
                           <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/"^^xsd:anyURI ;
                           rdfs:comment "Ontology developer in the framework of the EU project DIGIMAN4.0 with the support of Polimill and KMI in order to improve the retrieval of information from chip removal processes, especifically from the route cards or sheet cards" ,
                                        """“This work was conducted using Protégé.” 
Musen, M.A. The Protégé project: A look back and a look forward. AI Matters. Association of Computing Machinery Specific Interest Group in Artificial Intelligence, 1(4), June 2015. DOI: 10.1145/2557001.25757003.""" ;
                           rdfs:label "Machining Process Planning Ontology (MachPP)" ;
                           owl:priorVersion "1.0.0" ;
                           <http://www.w3.org/ns/dcat#accessURL> "https://w3id.org/MachPP"^^xsd:anyURI .

#################################################################
#    Annotation properties
#################################################################

###  http://creativecommons.org/ns#license
<http://creativecommons.org/ns#license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/dcat#accessURL
<http://www.w3.org/ns/dcat#accessURL> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart
<http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart> rdf:type owl:ObjectProperty .


###  https://w3id.org/kg4cut/hasInput
kg4cut:hasInput owl:equivalentProperty co:input ,
                                       MachPP:hasInputRole .


###  https://w3id.org/kg4cut/hasOutput
kg4cut:hasOutput owl:equivalentProperty co:output ,
                                        MachPP:hasOutputRole .


###  https://w3id.org/pmd/co/composedof
co:composedof rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty .


###  https://w3id.org/pmd/co/input
co:input rdf:type owl:ObjectProperty .


###  https://w3id.org/pmd/co/output
co:output rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#cuts
MachPP:cuts rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasComponent
MachPP:hasComponent rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart> .


###  https://www.w3id.org/MachPP#hasInputRole
MachPP:hasInputRole rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasManufacturer
MachPP:hasManufacturer rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasOutputRole
MachPP:hasOutputRole rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasParameter
MachPP:hasParameter rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasPredecessor
MachPP:hasPredecessor rdf:type owl:ObjectProperty ;
                      owl:inverseOf MachPP:hasSuccessor .


###  https://www.w3id.org/MachPP#hasSuccessor
MachPP:hasSuccessor rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasUnit
MachPP:hasUnit rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#hasWorkholding
MachPP:hasWorkholding rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#isFixedIn
MachPP:isFixedIn rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#isSpecificFor
MachPP:isSpecificFor rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#isSpecifiedBy
MachPP:isSpecifiedBy rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#isStoredIn
MachPP:isStoredIn rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#performs
MachPP:performs rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#produces
MachPP:produces rdf:type owl:ObjectProperty .


###  https://www.w3id.org/MachPP#transforms
MachPP:transforms rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/kg4cut/hasLength
kg4cut:hasLength owl:equivalentProperty MachPP:hasLength .


###  https://www.w3id.org/MachPP#GCode
MachPP:GCode rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#estimatesProduction
MachPP:estimatesProduction rdf:type owl:DatatypeProperty ;
                           rdfs:comment "Number of workpieces machined per hour" .


###  https://www.w3id.org/MachPP#hasBaseEdge
MachPP:hasBaseEdge rdf:type owl:DatatypeProperty ;
                   rdfs:domain MachPP:GeometricalShape ;
                   rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasCode
MachPP:hasCode rdf:type owl:DatatypeProperty ;
               rdfs:domain MachPP:Workpiece ;
               rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasDepth
MachPP:hasDepth rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain MachPP:GeometricalShape ;
                rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasDiameter
MachPP:hasDiameter rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain MachPP:GeometricalShape ;
                   rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasDuration
MachPP:hasDuration rdf:type owl:DatatypeProperty ;
                   rdfs:domain MachPP:Task ;
                   rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasFeedRate
MachPP:hasFeedRate rdf:type owl:DatatypeProperty ;
                   rdfs:domain MachPP:CuttingTool ;
                   rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasFinalGeometry
MachPP:hasFinalGeometry rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#hasISOCode
MachPP:hasISOCode rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:domain MachPP:CuttingTool ;
                  rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasInitialGeometry
MachPP:hasInitialGeometry rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#hasLength
MachPP:hasLength rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxCuttingTool
MachPP:hasMaxCuttingTool rdf:type owl:DatatypeProperty ;
                         rdfs:domain MachPP:CuttingToolStorage ;
                         rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasMaxDiameter
MachPP:hasMaxDiameter rdf:type owl:DatatypeProperty ;
                      rdfs:domain MachPP:Chuck ;
                      rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxSpeed
MachPP:hasMaxSpeed rdf:type owl:DatatypeProperty ;
                   rdfs:domain MachPP:CuttingTool ;
                   rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxSpindleSpeed
MachPP:hasMaxSpindleSpeed rdf:type owl:DatatypeProperty ;
                          rdfs:domain MachPP:Spindle .


###  https://www.w3id.org/MachPP#hasNumPasses
MachPP:hasNumPasses rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain MachPP:CuttingTool ;
                    rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasNumZ
MachPP:hasNumZ rdf:type owl:DatatypeProperty ;
               rdfs:domain MachPP:CuttingTool ;
               rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasPeckDepth
MachPP:hasPeckDepth rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain MachPP:CuttingTool ;
                    rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasPitch
MachPP:hasPitch rdf:type owl:DatatypeProperty ;
                rdfs:domain MachPP:GeometricalShape ;
                rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasPower
MachPP:hasPower rdf:type owl:DatatypeProperty ;
                rdfs:domain MachPP:Spindle .


###  https://www.w3id.org/MachPP#hasPrice
MachPP:hasPrice rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasProjectNumber
MachPP:hasProjectNumber rdf:type owl:DatatypeProperty ;
                        rdfs:domain MachPP:ManufacturingProcessPlan ;
                        rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasRecommendedSpeed
MachPP:hasRecommendedSpeed rdf:type owl:DatatypeProperty ;
                           rdfs:domain MachPP:CuttingTool ;
                           rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasThickness
MachPP:hasThickness rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain MachPP:MaterialRemoved ;
                    rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasTorque
MachPP:hasTorque rdf:type owl:DatatypeProperty ;
                 rdfs:domain MachPP:Spindle .


###  https://www.w3id.org/MachPP#hasValue
MachPP:hasValue rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasWidth
MachPP:hasWidth rdf:type owl:DatatypeProperty ;
                rdfs:domain MachPP:GeometricalShape ;
                rdfs:range xsd:float .


#################################################################
#    Classes
#################################################################

###  http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting
<http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting> rdf:type owl:Class ;
                                                                       rdfs:subClassOf MachPP:Task .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Moving
<http://resourcedescription.tut.fi/ontology/capabilityModel#Moving> rdf:type owl:Class ;
                                                                    rdfs:subClassOf MachPP:Task .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Picking
<http://resourcedescription.tut.fi/ontology/capabilityModel#Picking> rdf:type owl:Class ;
                                                                     rdfs:subClassOf MachPP:Task .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Placing
<http://resourcedescription.tut.fi/ontology/capabilityModel#Placing> rdf:type owl:Class ;
                                                                     rdfs:subClassOf MachPP:Task .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding
<http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding> rdf:type owl:Class ;
                                                                              rdfs:subClassOf MachPP:Task .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting
<http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting> rdf:type owl:Class ;
                                                                          rdfs:subClassOf MachPP:Task .


###  http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object
<http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object> owl:equivalentClass marco:IndividualDevice ;
                                                                     rdfs:subClassOf marco:Resource .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile> rdfs:subClassOf cm:Capability .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool> owl:equivalentClass MachPP:MachineTool .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand> rdfs:subClassOf cm:Capability .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction> rdfs:subClassOf cm:SimpleCapability .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure> rdfs:subClassOf cm:CapabilityParameterAdditional .


###  http://www.w3.org/ns/org#Organization
<http://www.w3.org/ns/org#Organization> owl:equivalentClass org:Organization .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#BoxShape
cm:BoxShape owl:equivalentClass MachPP:Prism ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty cm:hasShapeAndSize ;
                              owl:someValuesFrom kg4cut:Plane
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty cm:hasShapeAndSize ;
                              owl:someValuesFrom kg4cut:Shoulder
                            ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#ConeShape
cm:ConeShape owl:equivalentClass MachPP:Cone ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty cm:hasShapeAndSize ;
                               owl:someValuesFrom kg4cut:Chamfer
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty cm:hasShapeAndSize ;
                               owl:someValuesFrom kg4cut:Plane
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty cm:hasShapeAndSize ;
                               owl:someValuesFrom kg4cut:Shoulder
                             ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#CylinderShape
cm:CylinderShape owl:equivalentClass MachPP:Cylinder ;
                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty cm:hasShapeAndSize ;
                                   owl:someValuesFrom kg4cut:Plane
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty cm:hasShapeAndSize ;
                                   owl:someValuesFrom kg4cut:Shoulder
                                 ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#PyramidShape
cm:PyramidShape owl:equivalentClass MachPP:Frustum ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty cm:hasShapeAndSize ;
                                  owl:someValuesFrom kg4cut:Chamfer
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty cm:hasShapeAndSize ;
                                  owl:someValuesFrom kg4cut:Plane
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty cm:hasShapeAndSize ;
                                  owl:someValuesFrom kg4cut:Shoulder
                                ] .


###  https://resourcedescription.rd.tuni.fi/ontology/commonConcepts#MaterialType
<https://resourcedescription.rd.tuni.fi/ontology/commonConcepts#MaterialType> owl:equivalentClass MachPP:Material .


###  https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Device
marco:Device rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty MachPP:hasPrice ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:float
                             ] .


###  https://w3id.org/kg4cut/CuttingParameters
kg4cut:CuttingParameters rdfs:subClassOf MachPP:Parameter .


###  https://w3id.org/kg4cut/CuttingTool
kg4cut:CuttingTool owl:equivalentClass MachPP:CuttingTool .


###  https://w3id.org/kg4cut/MachineToolComponent
kg4cut:MachineToolComponent owl:equivalentClass MachPP:MachineToolComponent .


###  https://w3id.org/kg4cut/MachiningTask
kg4cut:MachiningTask rdfs:subClassOf MachPP:Task .


###  https://w3id.org/kg4cut/Thread
kg4cut:Thread rdf:type owl:Class ;
              rdfs:subClassOf kg4cut:FinalGeometry .


###  https://w3id.org/kg4cut/ToolType
kg4cut:ToolType rdfs:subClassOf cm:Capability .


###  https://www.w3.org/ns/org#Organization
org:Organization rdf:type owl:Class .


###  https://www.w3id.org/MachPP#BiddingQuote
MachPP:BiddingQuote rdf:type owl:Class ;
                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty marco:containsResource ;
                                      owl:someValuesFrom marco:Resource
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty cm:cycleTime_average ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onDataRange xsd:float
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty MachPP:hasPrice ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onDataRange xsd:float
                                    ] ;
                    rdfs:comment "A document that provide the cost and inclusions of a project created to suit customer requirements" .


###  https://www.w3id.org/MachPP#Chuck
MachPP:Chuck rdf:type owl:Class ;
             rdfs:subClassOf MachPP:Fixture .


###  https://www.w3id.org/MachPP#ClosingDoor
MachPP:ClosingDoor rdf:type owl:Class ;
                   rdfs:subClassOf MachPP:MachineOperation ;
                   owl:disjointWith MachPP:OpeningDoor .


###  https://www.w3id.org/MachPP#Cone
MachPP:Cone rdf:type owl:Class ;
            rdfs:subClassOf MachPP:ExternalShape .


###  https://www.w3id.org/MachPP#ConeCavity
MachPP:ConeCavity rdf:type owl:Class ;
                  rdfs:subClassOf MachPP:InternalShape ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty cm:hasShapeAndSize_internal ;
                                    owl:someValuesFrom kg4cut:Chamfer
                                  ] .


###  https://www.w3id.org/MachPP#ConicalFrustum
MachPP:ConicalFrustum rdf:type owl:Class ;
                      rdfs:subClassOf MachPP:Frustum ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty MachPP:hasDiameter ;
                                        owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                        owl:onDataRange xsd:float
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty MachPP:hasLength ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onDataRange xsd:float
                                      ] .


###  https://www.w3id.org/MachPP#CuttingSpeed
MachPP:CuttingSpeed rdf:type owl:Class ;
                    rdfs:subClassOf MachPP:Parameter ;
                    rdfs:label "vc" .


###  https://www.w3id.org/MachPP#CuttingTool
MachPP:CuttingTool rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:hasManufacturer ;
                                     owl:someValuesFrom MachPP:Manufacturer
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:hasParameter ;
                                     owl:someValuesFrom MachPP:Parameter
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:isSpecificFor ;
                                     owl:someValuesFrom MachPP:MachiningOperation
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:isStoredIn ;
                                     owl:someValuesFrom MachPP:Turret
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:performs ;
                                     owl:someValuesFrom MachPP:MachiningOperation
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty MachPP:cuts ;
                                     owl:allValuesFrom MachPP:Workpiece
                                   ] .


###  https://www.w3id.org/MachPP#CuttingToolStorage
MachPP:CuttingToolStorage rdf:type owl:Class ;
                          rdfs:subClassOf MachPP:MachineToolComponent .


###  https://www.w3id.org/MachPP#Cylinder
MachPP:Cylinder rdf:type owl:Class ;
                rdfs:subClassOf MachPP:ExternalShape ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty MachPP:hasDiameter ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onDataRange xsd:float
                                ] .


###  https://www.w3id.org/MachPP#CylindricalCavity
MachPP:CylindricalCavity rdf:type owl:Class ;
                         rdfs:subClassOf MachPP:InternalShape ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty cm:hasShapeAndSize_internal ;
                                           owl:someValuesFrom kg4cut:Hole
                                         ] .


###  https://www.w3id.org/MachPP#DrillingCuttingTool
MachPP:DrillingCuttingTool rdf:type owl:Class ;
                           rdfs:subClassOf MachPP:CuttingTool .


###  https://www.w3id.org/MachPP#DrillingOperation
MachPP:DrillingOperation rdf:type owl:Class ;
                         rdfs:subClassOf MachPP:MachiningOperation .


###  https://www.w3id.org/MachPP#ExternalFreeForm
MachPP:ExternalFreeForm rdf:type owl:Class ;
                        rdfs:subClassOf MachPP:ExternalShape ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cm:hasShapeAndSize ;
                                          owl:someValuesFrom <https://w3id.org/kg4cut/3DProfile>
                                        ] .


###  https://www.w3id.org/MachPP#ExternalHelix
MachPP:ExternalHelix rdf:type owl:Class ;
                     rdfs:subClassOf MachPP:ExternalShape ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty cm:hasShapeAndSize ;
                                       owl:someValuesFrom kg4cut:Thread
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty MachPP:hasDiameter ;
                                       owl:someValuesFrom xsd:float
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty MachPP:hasLength ;
                                       owl:someValuesFrom xsd:float
                                     ] ,
                                     [ rdf:type owl:Restriction ;
