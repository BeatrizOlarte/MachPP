MachPP:MachiningOperation rdf:type owl:Class ;
                          rdfs:subClassOf MachPP:Operation ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty MachPP:produces ;
                                            owl:someValuesFrom MachPP:Workpiece
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty MachPP:transforms ;
                                            owl:someValuesFrom MachPP:GeometricalShape
                                          ] .


