###  https://www.w3id.org/MachPP#Task
MachPP:Task rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty co:input ;
                              owl:someValuesFrom MachPP:Parameter
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty MachPP:hasInputRole ;
                              owl:someValuesFrom MachPP:Parameter
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty MachPP:hasPredecessor ;
                              owl:someValuesFrom MachPP:Task
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty MachPP:hasSuccessor ;
                              owl:someValuesFrom MachPP:Task
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty MachPP:isSpecifiedBy ;
                              owl:someValuesFrom MachPP:Operation
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty MachPP:hasDuration ;
                              owl:someValuesFrom xsd:float
                            ] ;
            rdfs:comment "Smallest level of granularity where it is possible to declare all the inputs required to obtain/create/produce the output"@en .


