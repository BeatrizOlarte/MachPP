###  https://www.w3id.org/MachPP#Task
<https://www.w3id.org/MachPP#Task> rdf:type owl:Class ;
                                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/pmd/co/input> ;
                                                     owl:someValuesFrom <https://www.w3id.org/MachPP#Parameter>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://www.w3id.org/MachPP#hasInputRole> ;
                                                     owl:someValuesFrom <https://www.w3id.org/MachPP#Parameter>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://www.w3id.org/MachPP#hasPredecessor> ;
                                                     owl:someValuesFrom <https://www.w3id.org/MachPP#Task>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://www.w3id.org/MachPP#hasSuccessor> ;
                                                     owl:someValuesFrom <https://www.w3id.org/MachPP#Task>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://www.w3id.org/MachPP#isSpecifiedBy> ;
                                                     owl:someValuesFrom <https://www.w3id.org/MachPP#Operation>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://www.w3id.org/MachPP#hasDuration> ;
                                                     owl:someValuesFrom xsd:float
                                                   ] ;
                                   rdfs:comment "Smallest level of granularity where it is possible to declare all the inputs required to obtain/create/produce the output"@en .


