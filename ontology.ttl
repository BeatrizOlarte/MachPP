<https://www.w3.org/ns/org#Organization> rdf:type owl:Class .


###  https://www.w3id.org/MachPP#BiddingQuote
<https://www.w3id.org/MachPP#BiddingQuote> rdf:type owl:Class ;
                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/resourceModel#containsResource> ;
                                                             owl:someValuesFrom <https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Resource>
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#cycleTime_average> ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onDataRange xsd:float
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://www.w3id.org/MachPP#hasPrice> ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onDataRange xsd:float
                                                           ] ;
                                           rdfs:comment "A document that provide the cost and inclusions of a project created to suit customer requirements" .


