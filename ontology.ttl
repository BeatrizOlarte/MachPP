#################################################################
#    Data properties
#################################################################

###  https://www.w3id.org/MachPP#GCode
<https://www.w3id.org/MachPP#GCode> rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#estimatesProduction
<https://www.w3id.org/MachPP#estimatesProduction> rdf:type owl:DatatypeProperty ;
                                                  rdfs:comment "Number of workpieces machined per hour" .


###  https://www.w3id.org/MachPP#hasBaseEdge
<https://www.w3id.org/MachPP#hasBaseEdge> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://www.w3id.org/MachPP#GeometricalShape> ;
                                          rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasCode
<https://www.w3id.org/MachPP#hasCode> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <https://www.w3id.org/MachPP#Workpiece> ;
                                      rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasDepth
<https://www.w3id.org/MachPP#hasDepth> rdf:type owl:DatatypeProperty ;
                                       rdfs:subPropertyOf owl:topDataProperty ;
                                       rdfs:domain <https://www.w3id.org/MachPP#GeometricalShape> ;
                                       rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasDiameter
<https://www.w3id.org/MachPP#hasDiameter> rdf:type owl:DatatypeProperty ;
                                          rdfs:subPropertyOf owl:topDataProperty ;
                                          rdfs:domain <https://www.w3id.org/MachPP#GeometricalShape> ;
                                          rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasDuration
<https://www.w3id.org/MachPP#hasDuration> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://www.w3id.org/MachPP#Task> ;
                                          rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasFeedRate
<https://www.w3id.org/MachPP#hasFeedRate> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                          rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasFinalGeometry
<https://www.w3id.org/MachPP#hasFinalGeometry> rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#hasISOCode
<https://www.w3id.org/MachPP#hasISOCode> rdf:type owl:DatatypeProperty ;
                                         rdfs:subPropertyOf owl:topDataProperty ;
                                         rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                         rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasInitialGeometry
<https://www.w3id.org/MachPP#hasInitialGeometry> rdf:type owl:DatatypeProperty .


###  https://www.w3id.org/MachPP#hasLength
<https://www.w3id.org/MachPP#hasLength> rdf:type owl:DatatypeProperty ;
                                        rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxCuttingTool
<https://www.w3id.org/MachPP#hasMaxCuttingTool> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <https://www.w3id.org/MachPP#CuttingToolStorage> ;
                                                rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasMaxDiameter
<https://www.w3id.org/MachPP#hasMaxDiameter> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <https://www.w3id.org/MachPP#Chuck> ;
                                             rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxSpeed
<https://www.w3id.org/MachPP#hasMaxSpeed> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                          rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasMaxSpindleSpeed
<https://www.w3id.org/MachPP#hasMaxSpindleSpeed> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <https://www.w3id.org/MachPP#Spindle> .


###  https://www.w3id.org/MachPP#hasNumPasses
<https://www.w3id.org/MachPP#hasNumPasses> rdf:type owl:DatatypeProperty ;
                                           rdfs:subPropertyOf owl:topDataProperty ;
                                           rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                           rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasNumZ
<https://www.w3id.org/MachPP#hasNumZ> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                      rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasPeckDepth
<https://www.w3id.org/MachPP#hasPeckDepth> rdf:type owl:DatatypeProperty ;
                                           rdfs:subPropertyOf owl:topDataProperty ;
                                           rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                           rdfs:range xsd:integer .


###  https://www.w3id.org/MachPP#hasPitch
<https://www.w3id.org/MachPP#hasPitch> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://www.w3id.org/MachPP#GeometricalShape> ;
                                       rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasPower
<https://www.w3id.org/MachPP#hasPower> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://www.w3id.org/MachPP#Spindle> .


###  https://www.w3id.org/MachPP#hasPrice
<https://www.w3id.org/MachPP#hasPrice> rdf:type owl:DatatypeProperty ;
                                       rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasProjectNumber
<https://www.w3id.org/MachPP#hasProjectNumber> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://www.w3id.org/MachPP#ManufacturingProcessPlan> ;
                                               rdfs:range xsd:string .


###  https://www.w3id.org/MachPP#hasRecommendedSpeed
<https://www.w3id.org/MachPP#hasRecommendedSpeed> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <https://www.w3id.org/MachPP#CuttingTool> ;
                                                  rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasThickness
<https://www.w3id.org/MachPP#hasThickness> rdf:type owl:DatatypeProperty ;
                                           rdfs:subPropertyOf owl:topDataProperty ;
                                           rdfs:domain <https://www.w3id.org/MachPP#MaterialRemoved> ;
                                           rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasTorque
<https://www.w3id.org/MachPP#hasTorque> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <https://www.w3id.org/MachPP#Spindle> .


###  https://www.w3id.org/MachPP#hasValue
<https://www.w3id.org/MachPP#hasValue> rdf:type owl:DatatypeProperty ;
                                       rdfs:range xsd:float .


###  https://www.w3id.org/MachPP#hasWidth
<https://www.w3id.org/MachPP#hasWidth> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://www.w3id.org/MachPP#GeometricalShape> ;
                                       rdfs:range xsd:float .


#################################################################
#    Classes
#################################################################

###  http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting
<http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Moving
<http://resourcedescription.tut.fi/ontology/capabilityModel#Moving> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Picking
<http://resourcedescription.tut.fi/ontology/capabilityModel#Picking> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Placing
<http://resourcedescription.tut.fi/ontology/capabilityModel#Placing> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding
<http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting
<http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <https://www.w3id.org/MachPP#Task> .


###  http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object
<http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object> rdf:type owl:Class ;
                                                                     owl:equivalentClass <https://resourcedescription.rd.tuni.fi/ontology/resourceModel#IndividualDevice> ;
                                                                     rdfs:subClassOf <https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Resource> .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#Capability> .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool> rdf:type owl:Class ;
                                                                       owl:equivalentClass <https://www.w3id.org/MachPP#MachineTool> .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#Capability> .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#SimpleCapability> .


###  http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure
<http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#CapabilityParameterAdditional> .


###  http://www.w3.org/ns/org#Organization
<http://www.w3.org/ns/org#Organization> rdf:type owl:Class ;
                                        owl:equivalentClass <https://www.w3.org/ns/org#Organization> .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#BoxShape
<https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#BoxShape> owl:equivalentClass <https://www.w3id.org/MachPP#Prism> ;
                                                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                             owl:someValuesFrom <https://w3id.org/kg4cut/Plane>
                                                                                           ] ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                             owl:someValuesFrom <https://w3id.org/kg4cut/Shoulder>
                                                                                           ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#ConeShape
<https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#ConeShape> owl:equivalentClass <https://www.w3id.org/MachPP#Cone> ;
                                                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                              owl:someValuesFrom <https://w3id.org/kg4cut/Chamfer>
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                              owl:someValuesFrom <https://w3id.org/kg4cut/Plane>
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                              owl:someValuesFrom <https://w3id.org/kg4cut/Shoulder>
                                                                                            ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#CylinderShape
<https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#CylinderShape> owl:equivalentClass <https://www.w3id.org/MachPP#Cylinder> ;
                                                                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                                  owl:someValuesFrom <https://w3id.org/kg4cut/Plane>
                                                                                                ] ,
                                                                                                [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                                  owl:someValuesFrom <https://w3id.org/kg4cut/Shoulder>
                                                                                                ] .


###  https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#PyramidShape
<https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#PyramidShape> owl:equivalentClass <https://www.w3id.org/MachPP#Frustum> ;
                                                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                                 owl:someValuesFrom <https://w3id.org/kg4cut/Chamfer>
                                                                                               ] ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                                 owl:someValuesFrom <https://w3id.org/kg4cut/Plane>
                                                                                               ] ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize> ;
                                                                                                 owl:someValuesFrom <https://w3id.org/kg4cut/Shoulder>
                                                                                               ] .


###  https://resourcedescription.rd.tuni.fi/ontology/commonConcepts#MaterialType
<https://resourcedescription.rd.tuni.fi/ontology/commonConcepts#MaterialType> owl:equivalentClass <https://www.w3id.org/MachPP#Material> .


###  https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Device
<https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Device> rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://www.w3id.org/MachPP#hasPrice> ;
                                                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                         owl:onDataRange xsd:float
                                                                                       ] .


