                                           rdfs:label "vc" .


###  https://www.w3id.org/MachPP#CuttingTool
<https://www.w3id.org/MachPP#CuttingTool> rdf:type owl:Class ;
                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#hasManufacturer> ;
                                                            owl:someValuesFrom <https://www.w3id.org/MachPP#Manufacturer>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#hasParameter> ;
                                                            owl:someValuesFrom <https://www.w3id.org/MachPP#Parameter>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#isSpecificFor> ;
                                                            owl:someValuesFrom <https://www.w3id.org/MachPP#MachiningOperation>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#isStoredIn> ;
                                                            owl:someValuesFrom <https://www.w3id.org/MachPP#Turret>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#performs> ;
                                                            owl:someValuesFrom <https://www.w3id.org/MachPP#MachiningOperation>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://www.w3id.org/MachPP#cuts> ;
                                                            owl:allValuesFrom <https://www.w3id.org/MachPP#Workpiece>
                                                          ] .


