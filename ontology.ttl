                                                                   owl:someValuesFrom <https://www.w3id.org/MachPP#Workpiece>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <https://www.w3id.org/MachPP#transforms> ;
                                                                   owl:someValuesFrom <https://www.w3id.org/MachPP#GeometricalShape>
                                                                 ] .


