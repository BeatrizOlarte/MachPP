}, {
  "@id" : "https://w3id.org/MachPP",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://creativecommons.org/ns#license" : [ {
    "@value" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@value" : "Beatriz Olarte"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "This ontology contains information and knowledge required to produce machining tasks and processes. This information is normally contained in route cards, giving its fine granularity level, it is decomposed into machining tasks. MachPP allows mapping information from machining processes to route cards. Allowing the usage of manufacturing features as input and output to each machining task to link it to the machining specifications selected by experts. \nThe ontology is linked to MarCo ontology and kg4cut, enabling to map the assets requested by a full machine tending quote or even a final project."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "Machining Process Planning Ontology (MachPP)"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Ontology developer in the framework of the EU project DIGIMAN4.0 with the support of Polimill and KMI in order to improve the retrieval of information from chip removal processes, especifically from the route cards or sheet cards"
  }, {
    "@value" : "“This work was conducted using Protégé.” \nMusen, M.A. The Protégé project: A look back and a look forward. AI Matters. Association of Computing Machinery Specific Interest Group in Artificial Intelligence, 1(4), June 2015. DOI: 10.1145/2557001.25757003."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Machining Process Planning Ontology (MachPP)"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://www.ontologydesignpatterns.org/cp/owl/partof.owl"
  }, {
    "@id" : "https://resourcedescription.rd.tuni.fi/ontology/resourceModel"
  }, {
    "@id" : "https://w3id.org/kg4cut/1.3.0"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@value" : "1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "MachPP:1.0.9"
  } ],
