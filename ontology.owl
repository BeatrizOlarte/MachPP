                <owl:someValuesFrom rdf:resource="https://www.w3id.org/MachPP#Workpiece"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.w3id.org/MachPP#transforms"/>
                <owl:someValuesFrom rdf:resource="https://www.w3id.org/MachPP#GeometricalShape"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


