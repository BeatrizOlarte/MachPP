    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#Inserting">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#Moving -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#Moving">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#Picking -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#Picking">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#Placing -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#Placing">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#TransportFeeding">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting -->


    <owl:Class rdf:about="http://resourcedescription.tut.fi/ontology/capabilityModel#Transporting">
        <rdfs:subClassOf rdf:resource="https://www.w3id.org/MachPP#Task"/>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object -->


    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object">
        <owl:equivalentClass rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/resourceModel#IndividualDevice"/>
        <rdfs:subClassOf rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/resourceModel#Resource"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile -->


    <owl:Class rdf:about="http://www.semanticweb.org/olart/ontologies/2024/0/InVor#CapabilityProfile">
        <rdfs:subClassOf rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#Capability"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool -->


    <owl:Class rdf:about="http://www.semanticweb.org/olart/ontologies/2024/0/InVor#MachineTool">
        <owl:equivalentClass rdf:resource="https://www.w3id.org/MachPP#MachineTool"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand -->


    <owl:Class rdf:about="http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCCommand">
        <rdfs:subClassOf rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#Capability"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction -->


    <owl:Class rdf:about="http://www.semanticweb.org/olart/ontologies/2024/0/InVor#NCFunction">
        <rdfs:subClassOf rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#SimpleCapability"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure -->


    <owl:Class rdf:about="http://www.semanticweb.org/olart/ontologies/2024/0/InVor#Structure">
        <rdfs:subClassOf rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#CapabilityParameterAdditional"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Organization -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Organization">
        <owl:equivalentClass rdf:resource="https://www.w3.org/ns/org#Organization"/>
    </owl:Class>
    


    <!-- https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#BoxShape -->


    <rdf:Description rdf:about="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#BoxShape">
        <owl:equivalentClass rdf:resource="https://www.w3id.org/MachPP#Prism"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/kg4cut/Plane"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/kg4cut/Shoulder"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#ConeShape -->


    <rdf:Description rdf:about="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#ConeShape">
        <owl:equivalentClass rdf:resource="https://www.w3id.org/MachPP#Cone"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/kg4cut/Chamfer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#hasShapeAndSize"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/kg4cut/Plane"/>
            </owl:Restriction>
        </rdfs:subClassOf>
