<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/MachPP#"
     xml:base="https://w3id.org/MachPP"
     xmlns:co="https://w3id.org/pmd/co/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns="http://creativecommons.org/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:MachPP="https://www.w3id.org/MachPP#"
     xmlns:resourceModel="https://resourcedescription.rd.tuni.fi/ontology/resourceModel#"
     xmlns:capabilityModel="https://resourcedescription.rd.tuni.fi/ontology/capabilityModel#"
     xmlns:cpannotationschema="http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#">
    <owl:Ontology rdf:about="https://w3id.org/MachPP">
        <owl:versionIRI rdf:resource="MachPP:1.0.9"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl"/>
        <owl:imports rdf:resource="https://resourcedescription.rd.tuni.fi/ontology/resourceModel"/>
        <owl:imports rdf:resource="https://w3id.org/kg4cut/1.3.0"/>
        <ns:license>https://creativecommons.org/licenses/by/4.0/</ns:license>
        <dc:creator>Beatriz Olarte</dc:creator>
        <dc:description xml:lang="en">This ontology contains information and knowledge required to produce machining tasks and processes. This information is normally contained in route cards, giving its fine granularity level, it is decomposed into machining tasks. MachPP allows mapping information from machining processes to route cards. Allowing the usage of manufacturing features as input and output to each machining task to link it to the machining specifications selected by experts. 
The ontology is linked to MarCo ontology and kg4cut, enabling to map the assets requested by a full machine tending quote or even a final project.</dc:description>
        <dc:title xml:lang="en">Machining Process Planning Ontology (MachPP)</dc:title>
        <terms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://creativecommons.org/licenses/by/4.0/</terms:license>
        <rdfs:comment>Ontology developer in the framework of the EU project DIGIMAN4.0 with the support of Polimill and KMI in order to improve the retrieval of information from chip removal processes, especifically from the route cards or sheet cards</rdfs:comment>
        <rdfs:comment>“This work was conducted using Protégé.” 
Musen, M.A. The Protégé project: A look back and a look forward. AI Matters. Association of Computing Machinery Specific Interest Group in Artificial Intelligence, 1(4), June 2015. DOI: 10.1145/2557001.25757003.</rdfs:comment>
        <rdfs:label>Machining Process Planning Ontology (MachPP)</rdfs:label>
        <owl:priorVersion>1.0.0</owl:priorVersion>
        <dcat:accessURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://w3id.org/MachPP</dcat:accessURL>
    </owl:Ontology>
    


